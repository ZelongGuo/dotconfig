[global]
    ### Display ###
    monitor = 0
    layer = top
    follow = mouse
    width = 360
    height = 300
    origin = top-right
    offset = 16x16
    scale = 0
    notification_limit = 8

    ### Progress bar ###
    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 0
    progress_bar_min_width = 150
    progress_bar_max_width = 300

    ### Notification appearance ###
    transparency = 0
    corner_radius = 10
    frame_width = 2
    gap_size = 8
    separator_height = 2
    padding = 14
    horizontal_padding = 14
    text_icon_padding = 10
    sort = yes
    shrink = no
    word_wrap = yes
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    ### Text ###
    font = Noto Sans CJK SC 10
    line_height = 2
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    ellipsize = middle

    ### Icons ###
    enable_recursive_icon_lookup = true
    icon_position = left
    min_icon_size = 24
    max_icon_size = 48
    icon_theme = Papirus-Dark, Papirus, Adwaita

    ### History ###
    sticky_history = yes
    history_length = 20

    ### Timeout ###
    idle_threshold = 120
    show_age_threshold = 60
    timeout = 6

    ### Behavior ###
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all
    mouse_wheel_up = history
    mouse_wheel_down = close_current

    ### Misc ###
    browser = xdg-open
    always_run_script = true
    title = Dunst
    class = Dunst
    ignore_dbusclose = false
    force_xwayland = false

[experimental]
    per_monitor_dpi = false

[urgency_low]
    background = "#1f2329"
    foreground = "#d8dee9"
    frame_color = "#4c566a"
    timeout = 4

[urgency_normal]
    background = "#1f2329"
    foreground = "#eceff4"
    frame_color = "#88c0d0"
    timeout = 6

[urgency_critical]
    background = "#2b1f1f"
    foreground = "#f8d7da"
    frame_color = "#bf616a"
    timeout = 0

[volume]
    appname = "pavucontrol"
    set_transient = yes

[device]
    summary = "*Keyboard*"
    timeout = 3

[bluetooth]
    appname = "blueman"
    timeout = 4

[fullscreen_delay_everything]
    fullscreen = delay
